require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

project 'ProofportApp.xcodeproj'

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'ProofportApp' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(require.resolve(\'expo-modules-autolinking\', { paths: [require.resolve(\'expo/package.json\')] }))(process.argv.slice(1))',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Suppress non-modular include warnings in GoogleSignIn pod
    installer.pods_project.targets.each do |target|
      if target.name == 'GoogleSignIn'
        target.build_configurations.each do |config|
          config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        end
      end

    end

    # Workaround for fmt 11.0.2 + clang 21 (Xcode 26.x) consteval mismatch in
    # format-inl.h. fmt's base.h sets FMT_USE_CONSTEVAL via an unconditional
    # `#define` chain (no `#ifndef` guard), so a `-DFMT_USE_CONSTEVAL=0`
    # compiler flag is silently overwritten by the header itself. The only
    # reliable fix is to patch the header so the resulting `#if` evaluates
    # to false — that drops the `consteval` keyword and makes the format
    # string constructors plain `constexpr`, which clang 21 accepts. Patch
    # is idempotent and runs on every `pod install`, so it survives Pods
    # regeneration.
    fmt_header = File.join(installer.sandbox.root, 'fmt/include/fmt/base.h')
    if File.exist?(fmt_header)
      content = File.read(fmt_header)
      patched = content.sub(
        /^#if FMT_USE_CONSTEVAL$/,
        '#if 0 // patched: force constexpr fallback for Xcode 26.x clang'
      )
      if content != patched
        File.write(fmt_header, patched)
        Pod::UI.puts "Patched fmt/base.h: forced FMT_USE_CONSTEVAL guard to 0".green
      end
    end
  end
end
